{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2020",
    "allowJs": true,
    "noImplicitAny": false,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "isolatedModules": true,
    "strict": false,
    "lib": ["DOM", "ES6", "ES2020"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
